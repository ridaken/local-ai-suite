# local-ai-suite v0.2 non-secret configuration.
# Copy to config/.env. Put credentials only in config/secrets/*.txt.

# Host-side persistent storage. Use absolute paths on production hosts.
DATA_ROOT=D:/ai-data
ZIM_DIR=D:/ai-data/zim
STATE_DIR=D:/ai-data/state
QDRANT_STORAGE=D:/ai-data/qdrant
STATE_DB=D:/ai-data/state/ingest.db

# Kiwix and citation routing.
KIWIX_URL=http://localhost:8080
KIWIX_PUBLIC_URL=http://localhost:8080
KIWIX_BOOK=
LIBRARY_XML_PATH=
KIWIX_DATA_DIR=/data
KIWIX_CATALOG_URL=https://library.kiwix.org/catalog/v2/entries

# Optional live providers. API values belong in kagi_api_key.txt and
# ncbi_api_key.txt; the Compose stack mounts those files into the services.
KAGI_SEARCH_URL=https://kagi.com/api/v0/search
NCBI_EMAIL=
NCBI_TOOL=local-ai-suite
ARXIV_API_URL=https://export.arxiv.org/api/query

# Retrieval behavior and result sizing.
KB_SEARCH_LIMIT=5
WEB_SEARCH_LIMIT=5
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=las_curated
EMBED_URL=http://localhost:8081/v1/embeddings
EMBED_MODEL=bge-m3
EMBED_DIM=1024
RERANK_URL=http://localhost:8082/v1/rerank
RERANK_MODEL=bge-reranker-v2-m3
HYBRID_VECTOR_CANDIDATES=20
HYBRID_KIWIX_CANDIDATES=20
CHUNK_MAX_CHARS=2000
CHUNK_OVERLAP_CHARS=200

# Hosted surfaces remain loopback-bound by default. Compose maps its internal
# listeners to these host ports and supplies credentials through Docker secrets.
MCP_HOST=127.0.0.1
MCP_PORT=8090
ADMIN_HOST=127.0.0.1
ADMIN_PORT=8091
KIWIX_PORT=8080
QDRANT_PORT=6333
ADMIN_COOKIE_SECURE=0

# Download safeguards. Defaults shown: 200 GiB max, 2 GiB reserve, one job.
DOWNLOAD_MAX_BYTES=214748364800
DOWNLOAD_MIN_FREE_BYTES=2147483648
DOWNLOAD_MAX_CONCURRENCY=1

# local-ai-suite configuration — copy to config/.env and edit.
# config/.env is gitignored; this .example file is the documented template.

# --- Data location -----------------------------------------------------------
# Everything large (ZIM corpora, and later Qdrant/models) lives under DATA_ROOT,
# on a drive of your choosing — NOT inside the repo. Point these at your data
# drive. Setup never auto-downloads corpora; you pull them explicitly.
# Use absolute paths (docker compose does not expand nested ${VARS} in env files).
DATA_ROOT=D:/ai-data
ZIM_DIR=D:/ai-data/zim

# --- Kiwix (offline knowledge base, full-text search) ------------------------
# URL the MCP gateway uses to query kiwix-serve. Default matches docker-compose.
KIWIX_URL=http://localhost:8080
# Optional: restrict kb_search to a single book (ZIM) by its metadata name.
# Leave blank to search across all served books.
KIWIX_BOOK=

# --- Web search (Kagi) -------------------------------------------------------
# Kagi Search API token. If blank, web_search returns a "not configured" notice.
KAGI_API_KEY=
KAGI_SEARCH_URL=https://kagi.com/api/v0/search

# --- PubMed (NCBI E-utilities, live) -----------------------------------------
# API key + email are optional but raise rate limits and are good manners.
NCBI_API_KEY=
NCBI_EMAIL=
NCBI_TOOL=local-ai-suite

# --- arXiv (live) ------------------------------------------------------------
ARXIV_API_URL=https://export.arxiv.org/api/query

# --- Gateway ------------------------------------------------------------------
# Default result counts (can be overridden per-call).
KB_SEARCH_LIMIT=5
WEB_SEARCH_LIMIT=5

# --- Phase 2: semantic retrieval (vector tier) -------------------------------
# Leave QDRANT_URL or EMBED_URL blank to disable the vector tier; kb_search then
# runs Kiwix-only lexical search (Phase 1 behaviour), so this is safe to defer.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=las_curated
# Where qdrant persists vectors (bind-mounted in docker-compose). Keep on SSD.
QDRANT_STORAGE=D:/ai-data/qdrant

# Embeddings + reranker, served by llama-server (OpenAI-compatible endpoints).
EMBED_URL=http://localhost:8081/v1/embeddings
EMBED_MODEL=bge-m3
EMBED_DIM=1024
RERANK_URL=http://localhost:8082/v1/rerank
RERANK_MODEL=bge-reranker-v2-m3

# Retrieval sizing and chunking (chars ~= 4 per token).
HYBRID_VECTOR_CANDIDATES=20
HYBRID_KIWIX_CANDIDATES=20
CHUNK_MAX_CHARS=2000
CHUNK_OVERLAP_CHARS=200
# Incremental ingest manifest (sqlite). Defaults under ingest/ if unset.
STATE_DB=D:/ai-data/state.db

# --- Phase 3: management plane (admin UI + MCP-over-HTTP) --------------------
# These matter when running the gateway as a service (`docker compose up`, or
# `LAS_TRANSPORT=http` directly on the host). Not used for pi's stdio launch.
# Runtime toggles (retrieval mode, rerank on/off, per-book enable/disable) —
# separate from this file since the admin UI edits it live.
SETTINGS_DB=D:/ai-data/settings.db
# Admin UI + /mcp bind address. Loopback by default; widen deliberately.
ADMIN_HOST=127.0.0.1
ADMIN_PORT=8090
# Where the gateway writes library.xml for kiwix's --library --monitorLibrary
# mode (lets the admin UI add/remove ZIMs without restarting kiwix). Defaults
# under ZIM_DIR; only override if you're not using the standard layout.
LIBRARY_XML_PATH=
# The path kiwix-serve sees ZIM_DIR at inside its own container — only
# relevant under docker-compose (gateway writes library.xml with this prefix).
KIWIX_DATA_DIR=/data
# Kiwix's public OPDS catalog, browsed from the admin UI's Sources page.
KIWIX_CATALOG_URL=https://library.kiwix.org/catalog/v2/entries
